#!/usr/bin/sh

refresh() {
	currentHeight=$(qdbus6 org.kde.plasmashell /PlasmaShell org.kde.PlasmaShell.evaluateScript 'print(panels()[0].height)' 2> /dev/null)
	qdbus6 org.kde.plasmashell /PlasmaShell org.kde.PlasmaShell.evaluateScript "panels()[0].height = $currentHeight + 1" 2> /dev/null
	sleep 0.1
	qdbus6 org.kde.plasmashell /PlasmaShell org.kde.PlasmaShell.evaluateScript "panels()[0].height = $currentHeight" 2> /dev/null
}

dbus-monitor --session "path='/org/kde/ScreenBrightness',interface='org.kde.ScreenBrightness'" | grep -Po "(?<=member=).*" --line-buffered | while IFS= read -r method; do
	echo $method
	case "$method" in
		DisplayAdded|DisplayRemoved)
			refresh
		;;
	esac
done &
PID1=$!

dbus-monitor --session "type='signal',interface='org.freedesktop.ScreenSaver',path=/org/freedesktop/ScreenSaver,member=ActiveChanged" | grep --line-buffered -Po "(?<=boolean )(true|false)" | while IFS= read -r state; do
	echo "Lock state changed: $state"
	if [ "$state" = "false" ]; then
		sleep 0.1
		refresh
	fi
done &
PID2=$!

CURPID=$$
cleanup() {
	pkill -P $CURPID
}
trap 'cleanup' EXIT SIGHUP SIGINT SIGQUIT SIGTERM SIGUSR1 SIGUSR2

wait $PID1
wait $PID2

